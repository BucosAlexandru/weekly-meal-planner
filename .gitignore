# Node dependencies
node_modules/

# Environment
.env
.env.local

# Build output
dist/
build/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# System files
.DS_Store
.env.local
.env.local
.env.local
.vercel

# Local helper files (do not commit)
/public/js/find-duplicates.js
/public/scripts/
check-ssl-expiry.cjs
check-ssl-expiry.js.claude/

# Recipe-generation scripts — local only, never committed.
# All .py and one-off helper scripts at repo root are throwaway tooling per
# CLAUDE.md ("audit_*.py"/"fix_*.py"/etc. are not a library). Block the whole
# class so accidental commits via web UI don't re-add them.
/*.py
/audit_*.py
/fix_*.py
/_*.py
/add_*.py

# Accidental image uploads (phone screenshots, drafts) at repo root.
# Recipe images live under public/images/.
/IMG_*.png
/IMG_*.jpg
/IMG_*.jpeg

# Claude Code worktrees
.claude/worktrees/

# Image curation workflow — only the public/images/<slug>.{webp,jpg} output
# should be committed. Raw sources live in ./sources/ locally and the manifest
# you point batch-image-add.mjs at is your private working file. The
# *.example.json template IS committed for reference.
sources/
data/image-batch.json
__pycache__/
*.pyc
