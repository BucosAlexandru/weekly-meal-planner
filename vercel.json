{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1.js"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ],
  "builds": [
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "redirects": [
    {
      "source": "/ro/bucatarie",
      "destination": "/ro/retete/",
      "permanent": true
    },
    {
      "source": "/ro/bucatarie/:path*",
      "destination": "/ro/retete/:path*",
      "permanent": true
    },
    {
      "source": "/en/cuisine",
      "destination": "/en/recipes/",
      "permanent": true
    },
    {
      "source": "/en/cuisine/:path*",
      "destination": "/en/recipes/:path*",
      "permanent": true
    },
    {
      "source": "/es/cocina",
      "destination": "/es/recetas/",
      "permanent": true
    },
    {
      "source": "/es/cocina/:path*",
      "destination": "/es/recetas/:path*",
      "permanent": true
    },
    {
      "source": "/fr/cuisine",
      "destination": "/fr/recettes/",
      "permanent": true
    },
    {
      "source": "/fr/cuisine/:path*",
      "destination": "/fr/recettes/:path*",
      "permanent": true
    },
    {
      "source": "/de/kueche",
